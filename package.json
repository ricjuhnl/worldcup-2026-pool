{
  "dependencies": {
    "firebase": "^12.7.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run:dev:server\" \"npm run:dev:web\"",
    "run:dev:server": "npm run dev --prefix server",
    "run:dev:web": "npm run dev --prefix web",
    "docker:build": "docker-compose -f server/docker-compose.yml build",
    "docker:up": "docker-compose -f server/docker-compose.yml up -d",
    "docker:down": "docker-compose -f server/docker-compose.yml down",
    "docker:logs": "docker-compose -f server/docker-compose.yml logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.x"
  }
}
